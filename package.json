{
  "name": "@holtzj/mcp-turo",
  "version": "1.0.0",
  "description": "MCP server for Turo peer-to-peer car rental automation",
  "author": {
    "name": "Accelerate Advisors",
    "email": "<holtzj@accelerate-advisors.net>"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "holtzj-mcp-turo": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run clean && npm rn build",
    "inspect": "npx @modelcontextprotocol/inspector --config mcp-inspector.json --server turo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holtzj/mcp-turo.git"
  },
  "bugs": {
    "url": "https://github.com/holtzj/mcp-turo/issues"
  },
  "homepage": "https://github.com/holtzj/mcp-turo#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "turo",
    "car-rental",
    "automation"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "patchright": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.0"
  },
  "mcpName": "io.github.holtzj/turo"
}
